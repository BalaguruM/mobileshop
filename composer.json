{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The Laravel Framework.",
    "keywords": ["framework", "laravel"],
    "license": "MIT",
    "require": {
        "php": "^8.4|^8.3",
        "barryvdh/laravel-debugbar": "^3.15",
        "barryvdh/laravel-dompdf": "^3.1",
        "barryvdh/laravel-elfinder": "^0.5.4",
        "guzzlehttp/guzzle": "^7.9",
        "intervention/image": "^2.7",
        "jenssegers/agent": "^2.6",
        "laravel/framework": "^12.0",
        "laravel/sanctum": "^4.0",
        "laravel/tinker": "^2.10",
        "league/flysystem-sftp-v3": "^3.28",
        "maatwebsite/excel": "^3.1",
        "mongodb/laravel-mongodb": "5.6",
        "mpdf/mpdf": "^8.2",
        "paragonie/sodium_compat": "^2.0",
        "posthog/posthog-php": "^3.7",
        "psr/log": "^3.0",
        "pusher/pusher-php-server": "^7.2",
        "setasign/fpdi": "^2.6",
        "smalot/pdfparser": "^2.10",
        "spatie/laravel-html": "^3.4",
        "spatie/laravel-permission": "^6.9.x-dev",
        "spatie/pdf-to-text": "^1.4",
        "stevebauman/location": "^7.6",
        "tecnickcom/tcpdf": "^6.7",
        "webklex/laravel-pdfmerger": "^1.0",
        "yajra/laravel-datatables-oracle": "^12.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/pint": "^1.18",
        "laravel/sail": "^1.33",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.4",
        "phpunit/phpunit": "^11.3",
        "spatie/laravel-ignition": "^2.8"
    },
    "autoload": {
        "files": ["app/Helpers/Helper.php"],
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
